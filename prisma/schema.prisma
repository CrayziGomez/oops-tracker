generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  role         String    @default("REPORTER") // REPORTER, ADMIN
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  comments     Comment[]
  issues       Issue[]   @relation("ReportedIssues")

  @@map("users")
}

model Project {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  issues      Issue[]

  @@map("projects")
}

model Issue {
  id          String       @id @default(cuid())
  title       String
  description String?
  severity    String       @default("MEDIUM") // CRITICAL, HIGH, MEDIUM, LOW, COSMETIC
  category    String       @default("BUG")    // BUG, FEATURE, UI_UX, PERFORMANCE, SECURITY, OTHER
  status      String       @default("OPEN")   // OPEN, ACTIONED, DONE, ARCHIVED
  projectId   String
  reporterId  String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  attachments Attachment[]
  comments    Comment[]
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  reporter    User         @relation("ReportedIssues", fields: [reporterId], references: [id])

  @@index([projectId])
  @@index([reporterId])
  @@index([status])
  @@index([severity])
  @@map("issues")
}

model Attachment {
  id        String   @id @default(cuid())
  url       String
  filename  String
  type      String
  size      Int?
  issueId   String
  createdAt DateTime @default(now())
  issue     Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)

  @@index([issueId])
  @@map("attachments")
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  issueId   String
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  author    User     @relation(fields: [authorId], references: [id])
  issue     Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)

  @@index([issueId])
  @@index([authorId])
  @@map("comments")
}
